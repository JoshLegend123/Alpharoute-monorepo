{
  "compilerOptions": {
    /* Target and Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,

    /* Emit */
    "outDir": "./dist",
    "rootDir": "./src",                          /* 👈 ADD THIS LINE TO FIX THE ERROR */
    "sourceMap": true
  },
  "include": ["src/**/*"]
}